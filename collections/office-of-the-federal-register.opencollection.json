    },
    {
      "info": {
        "name": "List Suggested Searches",
        "type": "http"
      },
      "http": {
        "method": "GET",
        "url": "https://www.federalregister.gov/api/v1/suggested_searches",
        "params": [
          {
            "name": "conditions[sections]",
            "value": "",
