            "description": "Filter to a specific section."
          }
        ]
      },
      "docs": "List the available suggested searches by topic section."
    },
    {
      "info": {
        "name": "Fetch a Single Suggested Search",
        "type": "http"
      },
      "http": {
        "method": "GET",
        "url": "https://www.federalregister.gov/api/v1/suggested_searches/:slug",
        "params": [
          {
